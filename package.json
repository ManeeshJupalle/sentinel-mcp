{
  "name": "sentinel-mcp",
  "version": "0.1.0",
  "description": "A lightweight, zero-config MCP server for codebase health analysis",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sentinel-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "npx tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "code-health",
    "static-analysis",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "overrides": {
    "ip-address": "^10.2.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ignore": "^7.0.3",
    "simple-git": "^3.27.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-python": "0.23.4",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
